# ==============================================================
# 环境变量配置模板 - 复制为 .env 后修改
# ==============================================================

# ── 应用 ─────────────────────────────────────────────────────
APP_NAME=media-asset-platform
APP_ENV=production
DEBUG=false
SECRET_KEY=请替换为随机字符串-至少32位

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=media_asset
POSTGRES_PASSWORD=请替换为强密码
POSTGRES_DB=media_asset

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── RabbitMQ (Celery Broker) ────────────────────────────────
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=请替换为强密码
CELERY_BROKER_URL=amqp://admin:请替换为强密码@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Elasticsearch ────────────────────────────────────────────
ES_HOST=elasticsearch
ES_PORT=9200
ES_INDEX_PREFIX=media_asset

# ── Milvus ───────────────────────────────────────────────────
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ── MinIO ────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=请替换为强密码
MINIO_BUCKET_ORIGINALS=originals
MINIO_BUCKET_THUMBNAILS=thumbnails
MINIO_BUCKET_PREVIEWS=previews
MINIO_SECURE=false

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=请替换为随机字符串-至少32位
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── AI 模型 ─────────────────────────────────────────────────
CLIP_MODEL_NAME=ViT-B-16
INSIGHTFACE_MODEL=buffalo_l
PADDLEOCR_LANG=ch
ASR_MODEL=paraformer-zh

# ── 上传限制 ─────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,bmp,tiff,webp
ALLOWED_VIDEO_TYPES=mp4,avi,mov,mkv,flv,wmv
