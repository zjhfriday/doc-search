# === Application ===
APP_NAME=media-asset-platform
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_V1_PREFIX=/api/v1

# === Database (PostgreSQL) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=media_asset

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# === RabbitMQ (Celery Broker) ===
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === Elasticsearch ===
ES_HOST=localhost
ES_PORT=9200
ES_INDEX_PREFIX=media_asset

# === Milvus ===
MILVUS_HOST=localhost
MILVUS_PORT=19530

# === MinIO (Object Storage) ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_ORIGINALS=originals
MINIO_BUCKET_THUMBNAILS=thumbnails
MINIO_BUCKET_PREVIEWS=previews
MINIO_SECURE=false

# === AI Models ===
CLIP_MODEL_NAME=ViT-B-16
CLIP_MODEL_PRETRAINED=openai
INSIGHTFACE_MODEL=buffalo_l
PADDLEOCR_LANG=ch
ASR_MODEL=paraformer-zh

# === JWT ===
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# === Upload ===
MAX_UPLOAD_SIZE_MB=500
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,bmp,tiff,webp
ALLOWED_VIDEO_TYPES=mp4,avi,mov,mkv,flv,wmv
